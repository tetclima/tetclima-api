HOST=0.0.0.0
PORT=1337

# Comma-separated browser origins allowed to call Strapi (Next.js dev + production site).
# Example: CORS_ORIGIN=https://www.tetclima.com,https://tetclima.com
CORS_ORIGIN=

# Optional: on next Strapi start, move all assets from the "API Uploads" folder to the Media
# Library root (same library; Strapi always puts REST /api/upload files in API Uploads by default).
# Set to true once, restart Strapi, verify in Admin, then remove this line or set to false.
# MOVE_MEDIA_FROM_API_UPLOADS_TO_ROOT=true
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database: sqlite (default) or postgres (e.g. Supabase PostgreSQL)
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=database/data.db

DATABASE_CLIENT=postgres
# From Supabase: Project Settings → Database → Connection string (URI).
# If db.*.supabase.co fails with getaddrinfo ENOTFOUND, the direct host may be IPv6-only; use the
# "Session pooler" URI instead (aws-0-*.pooler.supabase.com) — it has IPv4 and works better with Strapi.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_SSL=true
# Supabase uses a managed cert; set false unless you supply DATABASE_SSL_CA
DATABASE_SSL_REJECT_UNAUTHORIZED=false
# npm run import:products calls Strapi’s API; rows are stored in the database above while Strapi runs with this .env.

# --- Supabase Storage (persistent media; required for Render / production) ---
# 1. Supabase Dashboard → Storage → New bucket → name e.g. strapi-uploads → Public bucket
# 2. Project Settings → Storage → S3 → Generate access keys (server-side only)
# 3. Copy endpoint + region from that same S3 page
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_STORAGE_BUCKET=strapi-uploads
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_REGION=eu-central-1
# Optional override (default: https://<ref>.storage.supabase.co/storage/v1/s3)
# SUPABASE_S3_ENDPOINT=https://qrctryvjrnoqirqmsmjq.storage.supabase.co/storage/v1/s3
# Public URL base for product images (default: .../object/public/<bucket>)
# SUPABASE_STORAGE_PUBLIC_URL=https://your-ref.supabase.co/storage/v1/object/public/strapi-uploads
# After copying old public/uploads/ files once:
# npm run migrate:uploads-to-supabase
