{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "type": {
      "type": "enumeration",
      "enum": [
        "Инверторни",
        "Подови",
        "Касетъчни",
        "Мултисплит",
        "Канални",
        "Колонни",
        "Преносими"
      ]
    },
    "brand": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::article.article"
    },
    "model": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "price": {
      "type": "integer"
    },
    "efficiency": {
      "type": "string"
    },
    "badge": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "Specifications": {
      "type": "component",
      "component": "shared.specifications",
      "repeatable": false
    }
  }
}
