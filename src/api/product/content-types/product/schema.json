{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "type": {
      "type": "enumeration",
      "enum": [
        "Инверторен",
        "Хиперинверторен",
        "Подов",
        "Касетъчен",
        "Мултисплит",
        "Канален",
        "Колонен",
        "Преносим",
        "Стенен"
      ]
    },
    "brand": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "price": {
      "type": "integer"
    },
    "efficiency": {
      "type": "string"
    },
    "badge": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "Specifications": {
      "type": "component",
      "component": "shared.specifications",
      "repeatable": false
    },
    "isRefurbished": {
      "type": "boolean"
    },
    "isAvailable": {
      "type": "boolean",
      "default": true
    }
  }
}
